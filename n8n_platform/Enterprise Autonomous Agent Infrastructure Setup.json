    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "list",
          "value": "<__PLACEHOLDER_VALUE__sales_alerts_channel__>"
        },
        "text": "=:warning: *Revenue Leakage Detected*\n\n{{ $json.output.summary }}\n\n*Critical Insights:*\n{{ $json.output.insights.filter(i => i.category === 'revenue_leak' && i.severity === 'critical').map(i => `• ${i.description}\\n  Action: ${i.recommended_action}\\n  Impact: $${i.estimated_revenue_impact.toLocaleString()}`).join('\\n\\n') }}\n\n*Affected Accounts:* {{ $json.output.insights.flatMap(i => i.account_ids).join(', ') }}",
        "otherOptions": {
          "includeLinkToWorkflow": false
        }
      },
      "id": "8b697b72-2406-4a0e-9533-e3034c325ecc",
      "name": "Alert Sales Team - Revenue Leak",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.4,
      "position": [
        2064,
        304
      ],
      "webhookId": "e15f1b2f-ff6c-4cb1-9ec2-6f0d66a084b1"
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "list",
          "value": "<__PLACEHOLDER_VALUE__sales_opportunities_channel__>"
        },
        "text": "=:rocket: *High-Priority Deal Opportunity*\n\n{{ $json.output.summary }}\n\n*Top Opportunities:*\n{{ $json.output.insights.filter(i => i.category === 'high_probability' && (i.severity === 'critical' || i.severity === 'high')).map(i => `• ${i.description}\\n  Action: ${i.recommended_action}\\n  Potential Revenue: $${i.estimated_revenue_impact.toLocaleString()}`).join('\\n\\n') }}\n\n*Accounts to Prioritize:* {{ $json.output.insights.flatMap(i => i.account_ids).join(', ') }}",
        "otherOptions": {
          "includeLinkToWorkflow": false
        }
      },
      "id": "a4f87630-3cd3-42e6-b824-5eb230dab2e2",
      "name": "Alert Sales Team - High Priority Deal",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.4,
      "position": [
        2064,
        496
      ],
      "webhookId": "11c1e1fc-0310-420c-8072-736afb327a6e"
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "list",
          "value": "<__PLACEHOLDER_VALUE__executive_alerts_channel__>"
        },
        "text": "=:rotating_light: *Pipeline Risk Alert - Executive Action Required*\n\n{{ $json.output.summary }}\n\n*Critical Risks:*\n{{ $json.output.insights.filter(i => i.category === 'pipeline_risk' && i.severity === 'critical').map(i => `• ${i.description}\\n  Recommended Action: ${i.recommended_action}\\n  Revenue at Risk: $${i.estimated_revenue_impact.toLocaleString()}`).join('\\n\\n') }}\n\n*Total Revenue at Risk:* ${{ $json.output.insights.filter(i => i.category === 'pipeline_risk').reduce((sum, i) => sum + i.estimated_revenue_impact, 0).toLocaleString() }}",
        "otherOptions": {
          "includeLinkToWorkflow": false
        }
      },
      "id": "5361ea46-a7b2-4812-a9c6-2fe6b9ee9c07",
      "name": "Alert Executives - Pipeline Risk",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.4,
      "position": [
        2064,
        688
      ],
      "webhookId": "3656a952-dc43-4f38-ae0b-de0ee4c79fa4"
    },
    {
      "parameters": {
        "sendTo": "<__PLACEHOLDER_VALUE__executive_email__>",
        "subject": "=Revenue Intelligence Report - {{ new Date().toLocaleDateString() }}",
        "message": "=<html>\n<body style=\"font-family: Arial, sans-serif;\">\n<h2>Revenue Intelligence Daily Report</h2>\n<p><strong>Generated:</strong> {{ new Date().toLocaleString() }}</p>\n\n<h3>Executive Summary</h3>\n<p>{{ $json.output.summary }}</p>\n\n<h3>Key Metrics</h3>\n<ul>\n<li><strong>Revenue Leaks Detected:</strong> {{ $json.output.insights.filter(i => i.category === 'revenue_leak').length }}</li>\n<li><strong>High-Priority Opportunities:</strong> {{ $json.output.insights.filter(i => i.category === 'high_probability').length }}</li>\n<li><strong>Pipeline Risks:</strong> {{ $json.output.insights.filter(i => i.category === 'pipeline_risk').length }}</li>\n<li><strong>Total Revenue Impact:</strong> ${{ $json.output.insights.reduce((sum, i) => sum + Math.abs(i.estimated_revenue_impact), 0).toLocaleString() }}</li>\n</ul>\n\n<h3>Critical Actions Required</h3>\n{{ $json.output.insights.filter(i => i.severity === 'critical').map(i => `<div style=\"border-left: 4px solid #ff0000; padding-left: 10px; margin: 10px 0;\">\n<strong>${i.category.toUpperCase()}</strong><br/>\n${i.description}<br/>\n<em>Action: ${i.recommended_action}</em><br/>\nImpact: $${i.estimated_revenue_impact.toLocaleString()}\n</div>`).join('') }}\n\n<p><em>This is an automated report from the Revenue Intelligence Agent.</em></p>\n</body>\n</html>",
        "options": {}
      },
      "id": "66738b65-edf5-4ee2-a29f-08871aebcdb2",
      "name": "Send Executive Report",
      "type": "n8n-nodes-base.gmail",
