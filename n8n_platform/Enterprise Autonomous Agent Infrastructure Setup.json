    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT account_id, total_revenue, churn_risk_score, lifetime_value, last_activity_date FROM revenue_analytics WHERE last_updated >= DATEADD(day, -7, CURRENT_DATE()) LIMIT 100"
      },
      "id": "2cb030db-7281-49be-af58-81393785d6ce",
