    {
      "parameters": {
        "numberInputs": 4
      },
      "id": "26e7234f-1dd2-48a8-9183-d21a748fc6c8",
      "name": "Merge Revenue Data",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        704,
        560
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "id-1",
              "name": "data_source",
              "value": "={{ $json.source || 'unknown' }}",
              "type": "string"
            },
            {
              "id": "id-2",
              "name": "account_id",
              "value": "={{ $json.AccountId || $json.dealId || $json.customer || $json.account_id }}",
              "type": "string"
            },
            {
              "id": "id-3",
              "name": "revenue_amount",
              "value": "={{ $json.Amount || $json.amount || $json.total_revenue || 0 }}",
              "type": "number"
            },
            {
              "id": "id-4",
              "name": "deal_stage",
              "value": "={{ $json.StageName || $json.dealstage || 'unknown' }}",
              "type": "string"
            },
            {
              "id": "id-5",
              "name": "close_date",
              "value": "={{ $json.CloseDate || $json.closedate || $json.last_activity_date }}",
              "type": "string"
            },
            {
              "id": "id-6",
              "name": "risk_score",
              "value": "={{ $json.churn_risk_score || 0 }}",
              "type": "number"
            },
            {
              "id": "id-7",
              "name": "days_in_stage",
              "value": "={{ Math.floor((new Date() - new Date($json.LastModifiedDate || $json.hs_lastmodifieddate || Date.now())) / (1000 * 60 * 60 * 24)) }}",
              "type": "number"
            },
            {
              "id": "id-8",
              "name": "revenue_velocity",
              "value": "={{ ($json.Amount || 0) / Math.max(1, Math.floor((new Date($json.CloseDate || Date.now()) - new Date($json.CreatedDate || Date.now())) / (1000 * 60 * 60 * 24))) }}",
              "type": "number"
            }
          ]
        },
        "options": {}
      },
      "id": "4c570d46-bd36-47ab-9080-7672c63b7bde",
      "name": "Engineer Features",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        928,
        592
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an expert Revenue Intelligence Analyst specializing in detecting revenue opportunities, risks, and leakage patterns. Analyze the provided CRM, marketing, and financial data to identify:\n\n1. REVENUE LEAKAGE: Deals stuck in pipeline, stalled opportunities, at-risk renewals, pricing inconsistencies\n2. HIGH-PROBABILITY DEALS: Opportunities with strong engagement signals, fast velocity, ideal customer profile match\n3. PIPELINE RISKS: Deals with red flags like long sales cycles, low engagement, competitive threats, budget concerns\n\nFor each insight, provide:\n- Severity/Priority (Critical, High, Medium, Low)\n- Affected accounts/deals with IDs\n- Specific risk factors or opportunity signals\n- Recommended actions\n- Estimated revenue impact\n\nBe specific, data-driven, and actionable."
        }
      },
      "id": "f2389109-0ac0-4a04-bd6b-9f6c48246ff2",
      "name": "Revenue Intelligence AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1216,
        592
      ]
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "id",
          "value": "gpt-4o"
        },
        "builtInTools": {},
        "options": {
          "temperature": 0.2
        }
      },
      "id": "953e9df6-b8e7-41c6-b655-10e06127deca",
      "name": "OpenAI GPT-4",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        1152,
        816
      ]
    },
    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"revenue_leak_detected\": {\n      \"type\": \"boolean\",\n      \"description\": \"True if revenue leakage patterns are detected\"\n    },\n    \"high_probability_deal\": {\n      \"type\": \"boolean\",\n      \"description\": \"True if high-probability opportunities are identified\"\n    },\n    \"pipeline_risk\": {\n      \"type\": \"boolean\",\n      \"description\": \"True if pipeline risks are detected\"\n    },\n    \"insights\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"category\": {\n            \"type\": \"string\",\n            \"enum\": [\"revenue_leak\", \"high_probability\", \"pipeline_risk\"]\n          },\n          \"severity\": {\n            \"type\": \"string\",\n            \"enum\": [\"critical\", \"high\", \"medium\", \"low\"]\n          },\n          \"account_ids\": {\n            \"type\": \"array\",\n            \"items\": {\"type\": \"string\"}\n          },\n          \"description\": {\"type\": \"string\"},\n          \"recommended_action\": {\"type\": \"string\"},\n          \"estimated_revenue_impact\": {\"type\": \"number\"}\n        }\n      }\n    },\n    \"summary\": {\n      \"type\": \"string\",\n      \"description\": \"Executive summary of findings\"\n    }\n  },\n  \"required\": [\"revenue_leak_detected\", \"high_probability_deal\", \"pipeline_risk\", \"insights\", \"summary\"]\n}"
      },
      "id": "2b7a8ca4-83df-46c6-9785-09035ba8429e",
      "name": "Structured Analysis Output",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1408,
        816
      ]
    },
    {
      "parameters": {},
      "id": "b5c22815-d041-45eb-978c-dffb40d760bc",
      "name": "Revenue Calculator",
      "type": "@n8n/n8n-nodes-langchain.toolCalculator",
      "typeVersion": 1,
      "position": [
        1280,
        816
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.revenue_leak_detected }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "true"
                    }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.high_probability_deal }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "true"
                    }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.pipeline_risk }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "true"
                    }
                  }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "c0f527b0-1a0d-44c7-bd74-88681647e741",
